<div class="sidebar-label">
    @if (Leading is not null)
    {
        <span class="sidebar-label__leading">@Leading</span>
    }
    <span class="sidebar-label__text">
        <span class="sidebar-label__title">@Title</span>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <span class="sidebar-label__subtitle">@Subtitle</span>
        }
    </span>
</div>

@code {
    [Parameter] public RenderFragment? Leading { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
}
